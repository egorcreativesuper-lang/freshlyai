rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Freshly Firestore Security Rules
     * 
     * Core Philosophy:
     * This ruleset implements a strict User-Ownership model for personal data (profiles and products) 
     * while utilizing a Role-Based Access Control (RBAC) model for administrative tasks. 
     * By leveraging path-based authorization, we ensure that users can only access data 
     * nested under their own unique identifier, providing high performance and data isolation.
     *
     * Data Structure:
     * - /users/{userId}: Private user profile and settings.
     * - /users/{userId}/products/{productId}: Private inventory of food products.
     * - /promoCodes/{promoCodeId}: Global codes readable by all for validation.
     * - /appSettings/globalSettings: Global configuration readable by all.
     * - /roles_admin/{userId}: Role mapping where document existence indicates admin status.
     *
     * Key Security Decisions:
     * 1. Authorization Independence: User data is nested under `/users/{userId}`. This allows 
     *    instant validation of ownership by comparing the path variable to `request.auth.uid`.
     * 2. DBAC (Database Access Control): Admin permissions are determined by the existence of 
     *    a document in the `/roles_admin` collection, avoiding complex custom claims.
     * 3. Immutability: Critical relational fields like `userId` and `id` are enforced as 
     *    immutable during updates to prevent data hijacking or orphan records.
     * 4. Prototyping Flexibility: While ownership is strictly enforced, the schema (fields like 
     *    names or timestamps) remains flexible to allow for rapid frontend iteration.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Helper for update/delete to ensure the document exists and the requester owns it.
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the UserProfile entity. Restricts access to the profile owner.
     * @path /users/{userId}
     * @allow Authenticated user can (create) their own profile if ID matches.
     * @deny User 'A' attempting to (get) User 'B's profile.
     * @principle Path-based ownership and relational integrity for the primary ID.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for Product entity. Users manage their own food inventory.
       * @path /users/{userId}/products/{productId}
       * @allow User 'A' can (list) all products in their own products subcollection.
       * @deny User 'A' can (update) a product inside User 'B's subcollection.
       * @principle Subcollection isolation and immutable relational field enforcement.
       */
      match /products/{productId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.id == productId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId && request.resource.data.id == resource.data.id;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Global PromoCodes. Readable by all users for validation, writeable only by admins.
     * @path /promoCodes/{promoCodeId}
     * @allow Any signed-in user (get) a promo code to check if it's valid.
     * @deny Non-admin user (update) the usedCount of a promo code.
     * @principle Public read-only access for consumers with administrative write control.
     */
    match /promoCodes/{promoCodeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Global application settings (singleton).
     * @path /appSettings/globalSettings
     * @allow Any signed-in user (get) the current theme or notification status.
     * @deny Any non-admin user (update) the global settings.
     * @principle Structural segregation of configuration data.
     */
    match /appSettings/globalSettings {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Administrative roles. Existence of document defines the admin.
     * @path /roles_admin/{userId}
     * @allow An existing admin (list) all other administrators.
     * @deny A standard user (create) an admin document for themselves.
     * @principle DBAC (Database Access Control) using existence checks.
     */
    match /roles_admin/{userId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}